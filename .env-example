# Cyberful local runtime
CYBERFUL_OS_DIR=./mcps/cyberful-os
CYBERFUL_OS_AUTOSTART=1
CYBERFUL_OS_MCP_ENABLED=1
CYBER_BROWSER_MCP_ENABLED=1
# ── Browser channel ──────────────────────────────────────────────────────────
# Default: open-source Chromium (patchright's bundled Chrome-for-Testing). No proprietary Chrome, and a
# dedicated "cyberful" profile is provisioned on first launch. This is the baked, distribution-safe default.
CYBER_BROWSER_CHANNEL=chromium
# ── Optional: reuse a REAL Google Chrome logged into the target (reuse an authenticated session) ──
# Skips the login OTP (the login is already done) and passes Cloudflare. Put these in the `.env` of the
# directory you launch cyberful from — they OVERRIDE the baked defaults above; do not bake personal paths:
#   CYBER_BROWSER_CHANNEL=chrome
#   CYBER_BROWSER_USER_DATA_DIR=/path/to/.cyberful-chrome/<engagement>
# Log in with a Chrome launched using the SAME --use-mock-keychain flag cyberful uses (otherwise cookies
# encrypted under the macOS Keychain won't decrypt and the profile shows logged out); then FULLY QUIT it:
#   "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome" \
#     --user-data-dir=/path/to/.cyberful-chrome/<engagement> \
#     --use-mock-keychain --no-first-run --no-default-browser-check https://target.example
CYBER_BROWSER_CLEAR_COOKIES_ON_START=false
# Headless OWASP ZAP is prepared by the startup preflight and starts automatically per engagement.
# The browser proxy, CA trust, MCP key, and API key are wired by Cyberful without host-side setup.
CYBER_ZAP_ENABLED=1
CYBER_BROWSER_THROUGH_ZAP=1

# ── Codex-only pentest phases ────────────────────────────────────────────────
# Codex runs the complete phase chain.
CYBERFUL_SUBSYSTEM_MODEL=gpt-5.6-sol
# Reasoning effort (Codex presets, low→high): minimal | low | medium | high | xhigh | max | ultra
# `ultra` is Codex's top preset; the API enum tops at xhigh, so Codex maps max/ultra onto it.
CYBERFUL_SUBSYSTEM_EFFORT=ultra
WEB_SEARCH=1
