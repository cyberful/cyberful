FROM oven/bun:1.3.14-alpine@sha256:5acc90a93e91ff07bf72aa90a7c9f0fa189765aec90b47bdbf2152d2196383c0

LABEL org.opencontainers.image.title="cyberful-zap-bridge" \
      org.opencontainers.image.description="stdio MCP bridge for the Cyberful ZAP sidecar" \
      org.opencontainers.image.licenses="AGPL-3.0-only"

WORKDIR /app
COPY package.json bun.lock ./
RUN bun install --production --frozen-lockfile
COPY zap_bridge.mjs zap_history.mjs zap_http_request.mjs zap_policy.mjs zap_report_path.mjs ./
USER bun
ENTRYPOINT ["bun", "run", "/app/zap_bridge.mjs"]
